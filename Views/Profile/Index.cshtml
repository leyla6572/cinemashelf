@model CinemaShelf.Models.AppUser

@{
    ViewData["Title"] = Model.Username + " - Profil";
    int totalMovies = ViewBag.TotalMovies ?? 0;
    int watchlistCount = ViewBag.WatchlistCount ?? 0;
    int watchedCount = ViewBag.WatchedCount ?? 0;
    int reviewsCount = ViewBag.ReviewsCount ?? 0;
    int quotesCount = ViewBag.QuotesCount ?? 0; // 🌟 Yeni replik sayısı
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4" style="max-width: 950px;">

    <!-- ==================== ÜST PROFİL KARTI ==================== -->
    <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start gap-4 mb-4">
        <div class="profile-avatar bg-success text-dark d-flex align-items-center justify-content-center shadow-sm">
            <span class="fw-bold">@Model.Username?.Substring(0, 1).ToUpper()</span>
        </div>

        <div class="flex-grow-1 text-center text-md-start mt-2">
            <div class="d-flex flex-column flex-md-row align-items-center gap-2">
                <h2 class="fw-bold text-dark mb-0">@Model.Username</h2>
                <span class="badge bg-light text-muted border px-2 py-1 small fw-normal">Sinema Sever</span>
            </div>

            <div class="profile-meta d-flex flex-wrap justify-content-center justify-content-md-start gap-3 mt-3 text-muted small">
                <span><i class="bi bi-mortarboard"></i> Üniversite Öğrencisi</span>
                <span><i class="bi bi-calendar3"></i> Temmuz 2021 tarihinde katıldı</span>
            </div>

            <div class="d-flex justify-content-center justify-content-md-start gap-4 mt-3 pt-2 border-top border-light">
                <div>
                    <span class="fw-bold text-dark fs-5">@totalMovies</span>
                    <span class="text-muted small ms-1">Toplam Film</span>
                </div>
                <div>
                    <span class="fw-bold text-dark fs-5" id="watchlist-count-badge">@watchlistCount</span>
                    <span class="text-muted small ms-1">İzlenecekler</span>
                </div>
                <div>
                    <span class="fw-bold text-dark fs-5">@watchedCount</span>
                    <span class="text-muted small ms-1">İzlediklerim</span>
                </div>
                <div>
                    <span class="fw-bold text-dark fs-5">@reviewsCount</span>
                    <span class="text-muted small ms-1">Yorumlar</span>
                </div>
                <div>
                    <!-- 🌟 Replik İstatistiği -->
                    <span class="fw-bold text-dark fs-5">@quotesCount</span>
                    <span class="text-muted small ms-1">Replikler</span>
                </div>
            </div>
        </div>

        <div class="mt-3 mt-md-2">
            <button class="btn btn-sm btn-outline-dark rounded-pill px-3"><i class="bi bi-pencil"></i> Düzenle</button>
        </div>
    </div>

    <!-- ==================== SEKMELER (TABS) ==================== -->
    <ul class="nav nav-tabs custom-profile-tabs border-bottom" id="profileTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="watchlist-tab" data-bs-toggle="tab" data-bs-target="#watchlist-content" type="button" role="tab">
                İzlenecekler (<span id="watchlist-tab-count">@watchlistCount</span>)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="watched-tab" data-bs-toggle="tab" data-bs-target="#watched-content" type="button" role="tab">
                İzlediklerim (@watchedCount)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="allmovies-tab" data-bs-toggle="tab" data-bs-target="#allmovies-content" type="button" role="tab">
                Tüm Filmlerim (@totalMovies)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-content" type="button" role="tab">
                Yorumlar (@reviewsCount)
            </button>
        </li>
        <!-- 🌟 YENİ SEKMEMİZ: REPLİKLER -->
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="quotes-tab" data-bs-toggle="tab" data-bs-target="#quotes-content" type="button" role="tab">
                Replikler (@quotesCount)
            </button>
        </li>
    </ul>

    <!-- ==================== SEKME İÇERİKLERİ ==================== -->
    <div class="tab-content pt-4" id="profileTabsContent">

        <!-- 1. İZLENECEKLER SEKMESİ -->
        <div class="tab-pane fade show active" id="watchlist-content" role="tabpanel">
            @if (ViewBag.Watchlist != null && ((List<CinemaShelf.Models.UserMovie>)ViewBag.Watchlist).Any())
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3" id="watchlist-container-row">
                    @foreach (var userMovie in (List<CinemaShelf.Models.UserMovie>)ViewBag.Watchlist)
                    {
                        var movie = userMovie.Movie;
                        <div class="col" id="movie-col-@movie.Id">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-shelf-card">
                                <div class="position-relative">
                                    <div class="dropdown position-absolute top-0 end-0 m-2" style="z-index: 10;">
                                        <button class="btn btn-dark btn-sm rounded-circle opacity-75 border-0 d-flex align-items-center justify-content-center"
                                                style="width: 28px; height: 28px;" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical text-white small"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 small py-1">
                                            <li>
                                                <a class="dropdown-menu-item dropdown-item py-2 fw-medium text-success" href="javascript:void(0);"
                                                   onclick="openWatchedModal(@movie.Id, '@movie.Title')">
                                                    <i class="bi bi-check2-circle me-2"></i> İzledim
                                                </a>
                                            </li>
                                            <!-- YENİ ENTEGRASYON: Raftan Kaldır Butonu -->
                                            <li>
                                                <a class="dropdown-menu-item dropdown-item py-2 fw-medium text-danger" href="javascript:void(0);"
                                                   onclick="removeFromShelf(@movie.Id)">
                                                    <i class="bi bi-x-circle me-2"></i> Raftan Kaldır
                                                </a>
                                            </li>
                                        </ul>
                                    </div>

                                    <a href="/Movie/Details/@movie.TmdbId">
                                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                                        {
                                            <img src="https://image.tmdb.org/t/p/w500@(movie.PosterPath)" class="card-img-top" alt="@movie.Title" style="height: 220px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                                                <small class="small">Afiş Yok</small>
                                            </div>
                                        }
                                    </a>
                                </div>
                                <div class="card-body p-2 bg-info text-white text-center">
                                    <a href="/Movie/Details/@movie.TmdbId" class="text-decoration-none text-white">
                                        <h6 class="card-title fw-semibold text-truncate mb-0 small" title="@movie.Title">@movie.Title</h6>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted" id="watchlist-empty-message">
                    <p class="mb-2">İzlenecekler listeniz henüz boş... 🏜️</p>
                    <a href="/Home/Index" class="btn btn-sm btn-primary rounded-pill px-3">Film Keşfet</a>
                </div>
            }
            <!-- Dinamik boş mesajı için yedek konteyner (Eğer tüm filmler el ile silinirse tetiklenecek) -->
            <div class="text-center py-5 text-muted d-none" id="watchlist-dynamic-empty">
                <p class="mb-2">İzlenecekler listeniz henüz boş... 🏜️</p>
                <a href="/Home/Index" class="btn btn-sm btn-primary rounded-pill px-3">Film Keşfet</a>
            </div>
        </div>

        <div class="tab-pane fade" id="watched-content" role="tabpanel">
            <!-- Sadece Arama Kutusu -->
            <div class="mb-3 pt-2">
                <div class="col-md-5 col-lg-4">
                    <div class="input-group input-group-sm shadow-sm">
                        <span class="input-group-text bg-white border-secondary-subtle">🔍</span>
                        <input type="text" id="movie-search-input" class="form-control border-secondary-subtle" placeholder="İzlediğiniz filmlerde arayın...">
                    </div>
                </div>
            </div>
            @if (ViewBag.Watched != null && ((List<CinemaShelf.Models.UserMovie>)ViewBag.Watched).Any())
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                    @foreach (var userMovie in (List<CinemaShelf.Models.UserMovie>)ViewBag.Watched)
                    {
                        var movie = userMovie.Movie;
                        <div class="col watched-movie-card">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-shelf-card">
                                <div class="position-relative">
                                    <a href="/Movie/Details/@movie.TmdbId">
                                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                                        {
                                            <img src="https://image.tmdb.org/t/p/w500@(movie.PosterPath)" class="card-img-top" alt="@movie.Title" style="height: 220px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                                                <small class="small">Afiş Yok</small>
                                            </div>
                                        }
                                    </a>
                                </div>
                                <div class="card-body p-2 bg-success text-white text-center">
                                    <a href="/Movie/Details/@movie.TmdbId" class="text-decoration-none text-white">
                                        <h6 class="card-title fw-semibold text-truncate mb-0 small" title="@movie.Title">@movie.Title</h6>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <hr class="my-5" /> <div class="row">
                    <div class="col-md-6">

                        <div class="card shadow-sm mb-4 border border-secondary-subtle" style="border-width: 1.5px !important;">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-dark mb-3" style="font-size: 1.1rem;">Türlerine Göre İzledikleri</h5>
                                <ol class="list-group list-group-numbered list-group-flush" style="padding-left: 0;">
                                    @if (ViewBag.GenreStats != null && ((List<KeyValuePair<string, int>>)ViewBag.GenreStats).Any())
                                    {
                                        foreach (var genre in (List<KeyValuePair<string, int>>)ViewBag.GenreStats)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-start border-0 py-2 bg-transparent">
                                                <div class="ms-2 me-auto">
                                                    <div class="fw-semibold">@genre.Key</div>
                                                </div>
                                                <span class="badge bg-light text-muted rounded-pill">@genre.Value film</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="list-group-item border-0 py-2 text-muted small bg-transparent">Henüz tür verisi bulunmuyor.</li>
                                    }
                                </ol>
                            </div>
                        </div>

                        <div class="card shadow-sm mb-4 border border-secondary-subtle" style="border-width: 1.5px !important;">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-dark mb-3" style="font-size: 1.1rem;">Türlerine Göre İzledikleri</h5>
                                <ol class="list-group list-group-numbered list-group-flush" style="padding-left: 0;">
                                    @if (ViewBag.DirectorStats != null && ((List<KeyValuePair<string, int>>)ViewBag.DirectorStats).Any())
                                    {
                                        foreach (var director in (List<KeyValuePair<string, int>>)ViewBag.DirectorStats)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-start border-0 py-2 bg-transparent">
                                                <div class="ms-2 me-auto">
                                                    <div class="fw-semibold">@director.Key</div>
                                                </div>
                                                <span class="badge bg-light text-muted rounded-pill">@director.Value film</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="list-group-item border-0 py-2 text-muted small bg-transparent">Henüz yönetmen verisi bulunmuyor.</li>
                                    }
                                </ol>
                            </div>
                        </div>

                    </div>

                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-dark mb-4" style="font-size: 1.1rem;">Yıllara Göre İzledikleri</h5>
                                <div class="d-flex flex-wrap gap-3">
                                    @if (ViewBag.YearlyStats != null && ((dynamic)ViewBag.YearlyStats).Count > 0)
                                    {
                                        foreach (dynamic yearStat in ViewBag.YearlyStats)
                                        {
                                            <div class="border rounded p-3 text-center flex-fill" style="min-width: 140px; background-color: #fafafa;">
                                                <div class="fs-5 fw-bold text-dark mb-1">@yearStat.Year</div>
                                                <div class="text-muted small">@yearStat.MovieCount film</div>
                                                <div class="text-primary fw-semibold mt-1" style="font-size: 0.85rem;">
                                                    @(yearStat.TotalMinutes / 60) sa @(yearStat.TotalMinutes % 60) dk
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="col-12 text-center text-muted py-3">
                                            <p class="small mb-0">Yıllık izleme verisi bulunmuyor.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <p class="mb-0">Henüz izlenen filmler listeniz boş. 🍿</p>
                </div>
            }
        </div>

        <!-- 3. TÜM FİLMELER SEKMESİ -->
        <div class="tab-pane fade" id="allmovies-content" role="tabpanel">
            @if (Model?.UserMovies != null && Model.UserMovies.Any())
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                    @foreach (var userMovie in Model.UserMovies)
                    {
                        var movie = userMovie.Movie;

                        var cardBackgroundClass = userMovie.Status == CinemaShelf.Models.WatchStatus.Watched ? "bg-success" : "bg-info";
                        var badgeText = userMovie.Status == CinemaShelf.Models.WatchStatus.Watched ? "İzlendi" : "İzlenecek";
                        var badgeClass = userMovie.Status == CinemaShelf.Models.WatchStatus.Watched ? "bg-success-subtle text-success border-success-subtle" : "bg-info-subtle text-info border-info-subtle";

                        <div class="col movie-item-@movie.Id">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-shelf-card">
                                <div class="position-relative">
                                    <a href="/Movie/Details/@movie.TmdbId">
                                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                                        {
                                            <img src="https://image.tmdb.org/t/p/w500@(movie.PosterPath)" class="card-img-top" alt="@movie.Title" style="height: 220px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                                                <small class="small">Afiş Yok</small>
                                            </div>
                                        }
                                    </a>
                                </div>

                                <div class="card-body p-2 @cardBackgroundClass text-white text-center">
                                    <a href="/Movie/Details/@movie.TmdbId" class="text-decoration-none text-white">
                                        <h6 class="card-title fw-semibold text-truncate mb-0 small" title="@movie.Title" style="font-size: 0.82rem;">@movie.Title</h6>
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <p class="mb-0">Henüz profilinizde hiç film yok. 🎬</p>
                </div>
            }
        </div>

        <!-- 4. YORUMLAR SEKMESİ -->
        <div class="tab-pane fade" id="reviews-content" role="tabpanel">
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="d-flex flex-column gap-3" style="max-width: 750px; margin: 0 auto;">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedDate))
                    {
                        <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-success">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(review.Movie?.PosterPath))
                                    {
                                        <img src="https://image.tmdb.org/t/p/w92@(review.Movie.PosterPath)" class="rounded-2 shadow-sm" style="width: 45px; height: 65px; object-fit: cover;">
                                    }
                                    <div>
                                        <a href="/Movie/Details/@review.Movie?.TmdbId" class="text-decoration-none">
                                            <h6 class="fw-bold text-dark mb-1 hover-success">@review.Movie?.Title</h6>
                                        </a>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">
                                            <i class="bi bi-calendar3"></i> @review.CreatedDate.ToString("dd MMMM yyyy HH:mm")
                                        </small>
                                    </div>
                                </div>
                                <span class="badge bg-warning text-dark fw-bold px-2 py-1 rounded">⭐ @review.Rating / 10</span>
                            </div>
                            <p class="text-muted small mb-0 mt-2 card-text" style="white-space: pre-line; line-height: 1.5;">
                                "@review.Content"
                            </p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <p class="mb-0"><i class="bi bi-chat-left-text fs-3 mb-2 d-block"></i> Henüz bir film yorumu veya inceleme bulunmuyor.</p>
                </div>
            }
        </div>

        <!-- 🌟 5. YENİ: REPLİKLER SEKMESİ İÇERİĞİ -->
        <div class="tab-pane fade" id="quotes-content" role="tabpanel">
            <div class="d-flex flex-column gap-3" style="max-width: 750px; margin: 0 auto;">

                <!-- HIZLI REPLİK PAYLAŞMA ALANI (Giriş Kutusu) -->
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white mb-2">
                    <div class="d-flex gap-3">
                        <div class="bg-success text-dark d-flex align-items-center justify-content-center shadow-sm rounded-circle fw-bold flex-shrink-0" style="width: 42px; height: 42px; font-size: 1.1rem;">
                            @Model.Username?.Substring(0, 1).ToUpper()
                        </div>

                        <div class="flex-grow-1">
                            <div class="w-100 placeholder-box bg-light border rounded-pill px-3 py-2 text-muted small cursor-pointer border-light-subtle shadow-inner"
                                 onclick="toggleQuoteBox()" id="quotePlaceholder">
                                Unutulmaz bir film repliği paylaş...
                            </div>

                            <div id="realQuoteForm" class="d-none">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm border border-light-subtle rounded-3 text-muted" id="quoteMovieId" style="font-size: 0.8rem;">
                                        <option value="">-- Rafınızdan Bir Film Seçin --</option>
                                        @if (ViewBag.UserMoviesList != null)
                                        {
                                            foreach (var m in (List<CinemaShelf.Models.Movie>)ViewBag.UserMoviesList)
                                            {
                                                <option value="@m.Id">@m.Title</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <textarea class="form-control form-control-sm border border-light-subtle rounded-3 text-dark p-2"
                                              id="quoteContent" rows="3" placeholder="Hafızanıza kazınan o güzel cümleyi buraya ekleyin..." style="font-size: 0.85rem; resize: none;"></textarea>
                                </div>
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-sm btn-light border rounded-pill px-3 py-1" onclick="toggleQuoteBox()" style="font-size: 0.75rem;">İptal</button>
                                    <button type="button" class="btn btn-sm btn-success rounded-pill px-3 py-1 fw-medium" onclick="submitNewQuote()" style="font-size: 0.75rem;">Paylaş</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PAYLAŞILAN REPLİKLERİN LİSTESİ -->
                <div class="d-flex flex-column gap-3" id="quotesListContainer">
                    @if (Model.MovieQuotes != null && Model.MovieQuotes.Any())
                    {
                        foreach (var quote in Model.MovieQuotes.OrderByDescending(q => q.CreatedDate))
                        {
                            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white position-relative overflow-hidden">
                                <figure class="mb-0">
                                    <blockquote class="blockquote fs-6 text-dark fw-medium lh-base italic-quote">
                                        “@quote.Content”
                                    </blockquote>
                                    <figcaption class=" mt-2 mb-0 d-flex justify-content-between align-items-center">
                                        <div>
                                            <a href="/Movie/Details/@quote.Movie?.TmdbId" class="text-decoration-none fw-semibold text-success hover-underline" style="font-size: 0.82rem; margin-left: -4px;">
                                                @quote.Movie?.Title
                                            </a>
                                        </div>
                                        <small class="text-muted" style="font-size: 0.7rem;">
                                            <i class="bi bi-clock me-1"></i> @quote.CreatedDate.ToString("dd MMM yyyy")
                                        </small>
                                    </figcaption>
                                </figure>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted bg-white rounded-4 shadow-sm">
                            <p class="mb-1"><i class="bi bi-quote fs-3 d-block mb-1 text-success"></i> Henüz bir film repliği paylaşmadınız.</p>
                            <small class="text-muted">İlk repliğinizi yukarıdaki kutuyu kullanarak hemen paylaşın! 🎬</small>
                        </div>
                    }
                </div>

            </div>
        </div>

    </div>
</div>

<!-- ==================== İZLEDİM ETKİLEŞİM MODALI ==================== -->
<div class="modal fade" id="watchedStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3">
                <h5 class="modal-title fw-bold text-dark small">
                    <i class="bi bi-patch-check-fill text-success me-1"></i> <span id="modalMovieTitle">Film</span> Yapıtını İzledim
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="modalMovieId" />
                <div class="mb-3">
                    <label class="form-label text-dark fw-semibold small mb-2"><i class="bi bi-star-fill text-warning me-1"></i> Bu filme puanınız:</label>
                    <select class="form-select form-select-sm border rounded-3 text-muted" id="modalRating">
                        <option value="0">Puan Ver (İsteğe Bağlı)</option>
                        @for (int i = 10; i >= 1; i--)
                        {
                            <option value="@i">⭐ @i / 10</option>
                        }
                    </select>
                </div>
                <div class="mb-1">
                    <label class="form-label text-dark fw-semibold small mb-2"><i class="bi bi-pencil-square text-muted me-1"></i> Film hakkında düşünceleriniz:</label>
                    <textarea class="form-control form-control-sm border rounded-3 text-muted" id="modalComment" rows="4" placeholder="Fikirlerinizi buraya yazabilirsiniz..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-sm btn-light border rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-sm btn-dark rounded-pill px-4 fw-medium" onclick="submitShelfUpdate()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== JAVASCRIPT & AJAX ALANI ==================== -->
<script>
    // 🌟 Hızlı Giriş Kutusu Açma/Kapatma Tetikleyicisi
    function toggleQuoteBox() {
        const placeholder = document.getElementById('quotePlaceholder');
        const realForm = document.getElementById('realQuoteForm');
        const textarea = document.getElementById('quoteContent');

        if (realForm.classList.contains('d-none')) {
            placeholder.classList.add('d-none');
            realForm.classList.remove('d-none');
            textarea.focus();
        } else {
            realForm.classList.add('d-none');
            placeholder.classList.remove('d-none');
            document.getElementById('quoteMovieId').value = "";
            textarea.value = "";
        }
    }

    function openWatchedModal(movieId, movieTitle) {
        document.getElementById('modalMovieId').value = movieId;
        document.getElementById('modalMovieTitle').innerText = movieTitle;
        document.getElementById('modalRating').value = "0";
        document.getElementById('modalComment').value = "";

        var myModal = new bootstrap.Modal(document.getElementById('watchedStatusModal'));
        myModal.show();
    }

    function submitShelfUpdate() {
        const movieId = document.getElementById('modalMovieId').value;
        const rating = document.getElementById('modalRating').value;
        const comment = document.getElementById('modalComment').value;

        const data = {
            MovieId: parseInt(movieId),
            NewStatus: "Watched",
            Rating: parseInt(rating),
            Comment: comment
        };

        fetch('/Profile/UpdateShelfStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    location.reload();
                } else {
                    alert(result.message);
                }
            });
    }

    // 🌟 YENİ ENTEGRASYON: Raftan Kaldır AJAX Fonksiyonu (Dinamik Arayüz Güncellemeli)
    // 🌟 GÜNCEL ENTEGRASYON: Raftan Kaldır AJAX Fonksiyonu (Sayaç ve Kart Güncellemeli)
    function removeFromShelf(movieId) {
        if (confirm("Bu filmi izlenecekler listenizden kaldırmak istediğinize emin misiniz?")) {

            fetch(`/Profile/RemoveFromShelf?movieId=${movieId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {

                        // 1. Adım: İzlenecekler sekmesindeki kartı bul ve animasyonla sil
                        const movieCard = document.getElementById(`movie-col-${movieId}`);
                        if (movieCard) {
                            movieCard.style.transition = "all 0.4s ease";
                            movieCard.style.opacity = "0";
                            movieCard.style.transform = "scale(0.8)";
                            setTimeout(() => { movieCard.remove(); }, 400);
                        }

                        // 2. Adım: Tüm Filmlerim sekmesindeki kartı da bulup uçurur
                        const allMoviesCard = document.querySelector(`.movie-item-${movieId}`);
                        if (allMoviesCard) {
                            allMoviesCard.style.transition = "all 0.4s ease";
                            allMoviesCard.style.opacity = "0";
                            allMoviesCard.style.transform = "scale(0.8)";
                            setTimeout(() => { allMoviesCard.remove(); }, 400);
                        }

                        // 3. Adım: Sayaçları dinamik olarak düşürme
                        setTimeout(() => {
                            // A) İzlenecekler Sayaçlarını Güncelle
                            const badgeCount = document.getElementById('watchlist-count-badge');
                            const tabCount = document.getElementById('watchlist-tab-count');

                            if (badgeCount) {
                                let currentCount = parseInt(badgeCount.innerText) - 1;
                                badgeCount.innerText = currentCount >= 0 ? currentCount : 0;
                                if (tabCount) tabCount.innerText = currentCount >= 0 ? currentCount : 0;

                                // Eğer hiç film kalmadıysa boş liste mesajını göster
                                if (currentCount === 0) {
                                    const oldEmptyMsg = document.getElementById('watchlist-empty-message');
                                    if (oldEmptyMsg) {
                                        oldEmptyMsg.classList.remove('d-none');
                                    } else {
                                        const dynamicEmpty = document.getElementById('watchlist-dynamic-empty');
                                        if (dynamicEmpty) dynamicEmpty.classList.remove('d-none');
                                    }
                                }
                            }

                            // 🌟 B) YENİ EKLEME: "Tüm Filmlerim" Sekme Başlığındaki Sayacı Güncelle
                            const allMoviesTab = document.getElementById('allmovies-tab');
                            if (allMoviesTab) {
                                // Buton metnini alıyoruz (Örn: "Tüm Filmlerim (15)")
                                const text = allMoviesTab.innerText;

                                // Parantez içindeki sayıyı Regex ile buluyoruz
                                const match = text.match(/\((\d+)\)/);
                                if (match) {
                                    let totalMoviesCount = parseInt(match[1]) - 1;
                                    if (totalMoviesCount < 0) totalMoviesCount = 0;

                                    // Yeni metni yazıyoruz (Örn: "Tüm Filmlerim (14)")
                                    allMoviesTab.innerText = `Tüm Filmlerim (${totalMoviesCount})`;
                                }
                            }
                        }, 400);

                    } else {
                        alert(result.message || "Film kaldırılırken bir hata oluştu.");
                    }
                })
                .catch(err => {
                    console.error("Hata:", err);
                    alert("İstek gönderilirken sistemsel bir hata oluştu.");
                });
        }
    }
    // 🌟 Replik Gönderme AJAX Fonksiyonu
    function submitNewQuote() {
        const movieId = document.getElementById('quoteMovieId').value;
        const content = document.getElementById('quoteContent').value;

        if (!movieId || !content.trim()) {
            alert("Lütfen bir film seçin ve replik metnini doldurun!");
            return;
        }

        const data = {
            MovieId: parseInt(movieId),
            Content: content
        };

        fetch('/Profile/AddQuote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    location.reload();
                } else {
                    alert(result.message);
                }
            })
            .catch(err => console.error("Hata:", err));
    }

    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("movie-search-input");

        if (searchInput) {
            searchInput.addEventListener("input", function (e) {
                // Arama metnini al ve Türkçe karakterleri standardize et
                let searchTerm = e.target.value.toLowerCase().trim()
                    .replace(/ı/g, 'i').replace(/ğ/g, 'g').replace(/ü/g, 'u')
                    .replace(/ş/g, 's').replace(/ö/g, 'o').replace(/ç/g, 'c');

                // "İzlediklerim" içindeki tüm film sütunlarını yakala
                const movieCards = document.querySelectorAll("#watched-content .watched-movie-card");

                movieCards.forEach(function (card) {
                    // Kartın içindeki film adını al
                    let titleElement = card.querySelector("h6");
                    let title = titleElement ? titleElement.innerText.toLowerCase() : "";

                    title = title.replace(/ı/g, 'i').replace(/ğ/g, 'g').replace(/ü/g, 'u')
                        .replace(/ş/g, 's').replace(/ö/g, 'o').replace(/ç/g, 'c');

                    // Eşleşme kontrolü
                    if (title.includes(searchTerm)) {
                        card.style.display = ""; // Göster
                    } else {
                        card.style.display = "none"; // Gizle
                    }
                });
            });
        }
    });
</script>

