@model CinemaShelf.Models.AppUser

@{
    ViewData["Title"] = Model.Username + " - Profil";
    int totalMovies = ViewBag.TotalMovies ?? 0;
    int watchlistCount = ViewBag.WatchlistCount ?? 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4" style="max-width: 950px;">

    <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start gap-4 mb-4">
        <div class="profile-avatar bg-success text-dark d-flex align-items-center justify-content-center shadow-sm">
            <span class="fw-bold">@Model.Username?.Substring(0, 1).ToUpper()</span>
        </div>

        <div class="flex-grow-1 text-center text-md-start mt-2">
            <div class="d-flex flex-column flex-md-row align-items-center gap-2">
                <h2 class="fw-bold text-dark mb-0">@Model.Username</h2>
                <span class="badge bg-light text-muted border px-2 py-1 small fw-normal">Sinema Sever</span>
            </div>

            <div class="profile-meta d-flex flex-wrap justify-content-center justify-content-md-start gap-3 mt-3 text-muted small">
                <span><i class="bi bi-mortarboard"></i> Üniversite Öğrencisi</span>
                <span><i class="bi bi-calendar3"></i> Temmuz 2021 tarihinde katıldı</span>
            </div>

            <div class="d-flex justify-content-center justify-content-md-start gap-4 mt-3 pt-2 border-top border-light">
                <div>
                    <span class="fw-bold text-dark fs-5">@totalMovies</span>
                    <span class="text-muted small ms-1">Toplam Film</span>
                </div>
                <div>
                    <span class="fw-bold text-dark fs-5">@watchlistCount</span>
                    <span class="text-muted small ms-1">İzlenecekler</span>
                </div>
                <div>
                    <span class="fw-bold text-dark fs-5">0</span>
                    <span class="text-muted small ms-1">Yorumlar</span>
                </div>
            </div>
        </div>

        <div class="mt-3 mt-md-2 d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3"><i class="bi bi-share"></i> Paylaş</button>
            <button class="btn btn-sm btn-outline-dark rounded-pill px-3"><i class="bi bi-pencil"></i> Düzenle</button>
        </div>
    </div>

    <ul class="nav nav-tabs custom-profile-tabs border-bottom" id="profileTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="watchlist-tab" data-bs-toggle="tab" data-bs-target="#watchlist-content" type="button" role="tab">
                İzlenecekler (@watchlistCount)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="allmovies-tab" data-bs-toggle="tab" data-bs-target="#allmovies-content" type="button" role="tab">
                Tüm Filmleri (@totalMovies)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-content" type="button" role="tab">
                Yorumlar (0)
            </button>
        </li>
    </ul>

    <div class="tab-content pt-4" id="profileTabsContent">

        <div class="tab-pane fade show active" id="watchlist-content" role="tabpanel">
            @if (Model.UserMovies != null && Model.UserMovies.Any(um => um.Status == CinemaShelf.Models.WatchStatus.Watchlist))
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                    @foreach (var userMovie in Model.UserMovies.Where(um => um.Status == CinemaShelf.Models.WatchStatus.Watchlist))
                    {
                        var movie = userMovie.Movie;
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-shelf-card">
                                <div class="position-relative">
                                    <a href="/Movie/Details/@movie.TmdbId">
                                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                                        {
                                            <img src="https://image.tmdb.org/t/p/w500@(movie.PosterPath)" class="card-img-top" alt="@movie.Title" style="height: 220px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                                                <small class="small">Afiş Yok</small>
                                            </div>
                                        }
                                    </a>
                                </div>
                                <div class="card-body p-2 bg-light text-center">
                                    <a href="/Movie/Details/@movie.TmdbId" class="text-decoration-none">
                                        <h6 class="card-title fw-semibold text-truncate text-dark mb-0 small" title="@movie.Title">@movie.Title</h6>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <p class="mb-2">İzlenecekler listeniz henüz boş... 🏜️</p>
                    <a href="/Home/Index" class="btn btn-sm btn-primary rounded-pill px-3">Film Keşfet</a>
                </div>
            }
        </div>

        <div class="tab-pane fade" id="allmovies-content" role="tabpanel">
            @if (Model.UserMovies != null && Model.UserMovies.Any())
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                    @foreach (var userMovie in Model.UserMovies)
                    {
                        var movie = userMovie.Movie;
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-shelf-card">
                                <div class="position-relative">
                                    <a href="/Movie/Details/@movie.TmdbId">
                                        @if (!string.IsNullOrEmpty(movie.PosterPath))
                                        {
                                            <img src="https://image.tmdb.org/t/p/w500@(movie.PosterPath)" class="card-img-top" alt="@movie.Title" style="height: 220px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                                                <small class="small">Afiş Yok</small>
                                            </div>
                                        }
                                    </a>
                                </div>
                                <div class="card-body p-2 bg-light text-center">
                                    <a href="/Movie/Details/@movie.TmdbId" class="text-decoration-none">
                                        <h6 class="card-title fw-semibold text-truncate text-dark mb-0 small" title="@movie.Title">@movie.Title</h6>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <p>Henüz rafınıza hiçbir film eklemediniz.</p>
                </div>
            }
        </div>

        <div class="tab-pane fade" id="reviews-content" role="tabpanel">
            <div class="text-center py-5 text-muted">
                <p class="mb-0"><i class="bi bi-chat-left-text fs-3 mb-2 d-block"></i> Henüz bir film yorumu veya inceleme bulunmuyor.</p>
            </div>
        </div>

    </div>
</div>

<style>
    /* Yuvarlak Avatar Alanı */
    .profile-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        font-size: 2.2rem;
        flex-shrink: 0;
    }

    /* Meta Bilgileri İkon Boşlukları */
    .profile-meta i {
        margin-right: 4px;
    }

    /* 1000Kitap Tarzı Alt Çizgili Sekme Tasarımı */
    .custom-profile-tabs .nav-link {
        border: none !important;
        color: #6c757d;
        font-weight: 600;
        padding: 10px 20px;
        background: transparent !important;
    }

        .custom-profile-tabs .nav-link:hover {
            color: #212529;
        }

        .custom-profile-tabs .nav-link.active {
            color: #212529 !important;
            border-bottom: 3px solid #212529 !important; /* Aktif sekmenin altına kalın çizgi */
        }

    /* Film Kartları Hover Efekti */
    .movie-shelf-card {
        transition: transform 0.2s ease;
    }

        .movie-shelf-card:hover {
            transform: translateY(-4px);
        }
</style>