@model CinemaShelf.Models.HomeViewModel

@{
    ViewData["Title"] = "Ana Sayfa - Kategoriler";
}

<div class="container mt-4">

    <!-- 💥 Aksiyon Filmleri -->
    <div class="mb-5">
        <h3 class="fw-bold text-dark mb-3">💥 Aksiyon Filmleri</h3>
        <div class="movie-row-container">
            @if (Model.ActionMovies != null && Model.ActionMovies.Any())
            {
                @foreach (var movie in Model.ActionMovies)
                {
                    <div class="movie-row-item">
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-card">
                            <div class="position-relative">
                                <a href="/Movie/Details/@movie.Id">
                                    @if (!string.IsNullOrEmpty(movie.Poster_Path))
                                    {
                                        <img src="https://image.tmdb.org/t/p/w500@(movie.Poster_Path)" class="card-img-top" alt="@movie.Title" style="height: 280px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 280px;">
                                            <span>Afiş Yok</span>
                                        </div>
                                    }
                                </a>
                                <span class="position-absolute top-0 end-0 bg-warning text-dark fw-bold m-2 px-2 py-1 rounded shadow-sm small">
                                    ⭐ @movie.Vote_Average.ToString("0.0")
                                </span>
                            </div>
                            <div class="card-body p-2 bg-light text-center">
                                <a href="/Movie/Details/@movie.Id" class="text-decoration-none">
                                    <h6 class="card-title fw-bold text-truncate mb-2 text-dark" title="@movie.Title">@movie.Title</h6>
                                </a>
                                <button class="btn btn-outline-primary btn-xs w-100 rounded-pill fw-semibold btn-sm"
                                        onclick="addToShelf('@movie.Id', '@movie.Title.Replace("'", "\\'")', '@movie.Poster_Path')">
                                    ➕ Rafa Ekle
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- Aksiyon için Daha Fazla (Genre ID: 28) -->
                <div class="movie-row-item d-flex align-items-center">
                    <div class="load-more-card" onclick="loadMoreMovies(28, this)">
                        <div class="icon-circle"><span>❯</span></div>
                        <small class="fw-bold text-muted d-block mt-2">Daha Fazla</small>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted ps-3">Bu kategoride film bulunamadı.</p>
            }
        </div>
    </div>

