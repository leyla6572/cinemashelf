<style>
    .movie-row-container {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        padding-bottom: 15px;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }

        /* Tarayıcıların varsayılan çirkin kaydırma çubuklarını gizliyoruz */
        .movie-row-container::-webkit-scrollbar {
            display: none;
        }

    .movie-row-container {
        -ms-overflow-style: none; /* IE ve Edge */
        scrollbar-width: none; /* Firefox */
    }

    .movie-row-item {
        flex: 0 0 auto;
        width: 200px;
        margin-right: 15px;
    }

    .movie-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .movie-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
        }
</style>

<script>
    function addToShelf(tmdbId, title, posterPath) {
        const movieData = {
            TmdbId: parseInt(tmdbId),
            Title: title,
            Overview: "",
            PosterPath: posterPath
        };

        fetch('/Profile/AddToUserShelf', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(movieData)
        })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
            })
            .catch(error => {
                console.error('Hata:', error);
                alert('Hesabınız olmadığı için rafa eklenemedi. Lütfen giriş yapınız.');
            });
    }
</script>