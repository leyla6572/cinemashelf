<style>
    .movie-row-container {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        padding-bottom: 15px;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }

        .movie-row-container::-webkit-scrollbar {
            display: none;
        }

    .movie-row-container {
        -ms-overflow-style: none; /* IE ve Edge */
        scrollbar-width: none; /* Firefox */
    }

    .movie-row-item {
        flex: 0 0 auto;
        width: 200px;
        margin-right: 15px;
    }

    .movie-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .movie-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
        }

    /* ── DAHA FAZLA OK BUTONU ÖZEL STİLLERİ ── */
    .load-more-card {
        width: 150px;
        height: 320px; /* Film kartlarının toplam yüksekliğiyle dengeli durması için */
        background: #fdfdfd;
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-left: 5px;
    }

        .load-more-card:hover {
            background: #f1f5f9;
            border-color: #0d6efd; /* Bootstrap primary mavi rengi */
            transform: scale(1.03);
        }

    .icon-circle {
        width: 45px;
        height: 45px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.06);
        color: #0d6efd;
        font-size: 18px;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .load-more-card:hover .icon-circle {
        transform: translateX(5px);
        background: #0d6efd;
        color: white;
    }
</style>

<script>
    // Her kategorinin kendi sayfa takibini tutan nesne (Sayfa 2'den başlıyor)
    const categoryPages = {};

    function loadMoreMovies(genreId, buttonElement) {
        if (!categoryPages[genreId]) {
            categoryPages[genreId] = 2;
        } else {
            categoryPages[genreId]++;
        }

        const nextPage = categoryPages[genreId];
        const iconCircle = buttonElement.querySelector('.icon-circle');

        // Butonu animasyonlu yükleniyor simgesine çevir
        iconCircle.innerHTML = `<span class="spinner-border spinner-border-sm" role="status"></span>`;

        fetch(`/Home/GetMoreMovies?genreId=${genreId}&page=${nextPage}`)
            .then(response => response.json())
            .then(movies => {
                if (movies && movies.length > 0) {
                    movies.forEach(movie => {
                        // C# tarafındaki veri modeli veya TMDB adlandırmalarını desteklemesi için
                        const movieTitle = movie.title || movie.Title || "İsimsiz Film";
                        const posterPath = movie.poster_Path || movie.poster_path || movie.Poster_Path || "";
                        const voteAverage = movie.vote_Average || movie.vote_average || movie.Vote_Average || 0;
                        const movieId = movie.id || movie.Id;

                        // Güvenli başlık tırnaklama temizliği
                        const safeTitle = movieTitle.replace(/'/g, "\\'");

                        // Dinamik film kartı şablonu (Orijinal kart tasarımı ile birebir aynıdır)
                        const movieHtml = `
                                <div class="movie-row-item">
                                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-card">
                                        <div class="position-relative">
                                            <a href="/Movie/Details/${movieId}">
                                                ${posterPath
                                ? `<img src="https://image.tmdb.org/t/p/w500${posterPath}" class="card-img-top" alt="${movieTitle}" style="height: 280px; object-fit: cover;">`
                                : `<div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 280px;"><span>Afiş Yok</span></div>`
                            }
                                            </a>
                                            <span class="position-absolute top-0 end-0 bg-warning text-dark fw-bold m-2 px-2 py-1 rounded shadow-sm small">
                                                ⭐ ${parseFloat(voteAverage).toFixed(1)}
                                            </span>
                                        </div>
                                        <div class="card-body p-2 bg-light text-center">
                                            <a href="/Movie/Details/${movieId}" class="text-decoration-none">
                                                <h6 class="card-title fw-bold text-truncate mb-2 text-dark" title="${movieTitle}">${movieTitle}</h6>
                                            </a>
                                            <button class="btn btn-outline-primary btn-xs w-100 rounded-pill fw-semibold btn-sm"
                                                    onclick="addToShelf('${movieId}', '${safeTitle}', '${posterPath}')">
                                                ➕ Rafa Ekle
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            `;

                        // Kartı, "Daha Fazla" butonunun içinde olduğu `.movie-row-item` div'inin tam soluna yerleştirir
                        buttonElement.parentElement.insertAdjacentHTML('beforebegin', movieHtml);
                    });

                    // Simgesini eski haline geri getir
                    iconCircle.innerHTML = '❯';
                } else {
                    // Sayfa boş geldiyse, artık daha fazla film yok demektir; butonu kaldırır
                    buttonElement.parentElement.remove();
                }
            })
            .catch(error => {
                console.error('Filmler getirilirken hata oluştu:', error);
                iconCircle.innerHTML = '❯';
            });
    }

    function addToShelf(tmdbId, title, posterPath) {
        const movieData = {
            TmdbId: parseInt(tmdbId),
            Title: title,
            Overview: "",
            PosterPath: posterPath
        };

        fetch('/Profile/AddToUserShelf', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(movieData)
        })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
            })
            .catch(error => {
                console.error('Hata:', error);
                alert('Hesabınız olmadığı için rafa eklenemedi. Lütfen giriş yapınız.');
            });
    }
</script>