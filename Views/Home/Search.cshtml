@model List<CinemaShelf.Models.TmdbMovieResult>

@{
    ViewData["Title"] = ViewData["SearchQuery"] + " Arama Sonuçları";
}

<div class="container mt-4">
    <div class="mb-4">
        <a href="/Home/Index" class="btn btn-sm btn-outline-secondary rounded-pill mb-2">⬅️ Ana Sayfaya Dön</a>
        <h2 class="fw-bold text-dark">🔍 "@ViewData["SearchQuery"]" İçin Arama Sonuçları</h2>
        <p class="text-muted">Toplam @(Model?.Count ?? 0) sonuç listelendi.</p>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var movie in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden movie-card">

                        <div class="position-relative">
                            <a href="/Movie/Details/@movie.Id">
                                @if (!string.IsNullOrEmpty(movie.Poster_Path))
                                {
                                    <img src="https://image.tmdb.org/t/p/w500@(movie.Poster_Path)" class="card-img-top" alt="@movie.Title" style="height: 380px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 380px;">
                                        <span>Afiş Yok</span>
                                    </div>
                                }
                            </a>

                            <span class="position-absolute top-0 end-0 bg-warning text-dark fw-bold m-2 px-2 py-1 rounded shadow-sm">
                                ⭐ @movie.Vote_Average.ToString("0.0")
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column justify-content-between bg-light">
                            <div>
                                <a href="/Movie/Details/@movie.Id" class="text-decoration-none">
                                    <h5 class="card-title fw-bold text-truncate text-dark" title="@movie.Title">@movie.Title</h5>
                                </a>
                                <p class="card-text text-muted small text-clamp" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @(string.IsNullOrEmpty(movie.Overview) ? "Bu film için henüz bir özet eklenmemiş." : movie.Overview)
                                </p>
                            </div>

                            <div class="mt-3">
                                <button class="btn btn-outline-primary btn-sm w-100 rounded-pill fw-semibold"
                                        onclick="addToShelf('@movie.Id', '@movie.Title.Replace("'", "\\'")', '@movie.Poster_Path')">
                                    ➕ Rafa Ekle
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">Aradığınız kriterlere uygun film bulunamadı. 😥</h4>
                <p class="text-muted small">Farklı anahtar kelimelerle tekrar deneyebilirsiniz.</p>
            </div>
        }
    </div>
</div>

<style>
    .movie-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .movie-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }
</style>

<script>
    function addToShelf(tmdbId, title, posterPath) {
        const movieData = {
            TmdbId: parseInt(tmdbId),
            Title: title,
            Overview: "",
            PosterPath: posterPath
        };

        fetch('/Profile/AddToUserShelf', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(movieData)
        })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
            })
            .catch(error => {
                console.error('Hata:', error);
                alert('Hesabınız olmadığı için rafa eklenemedi. Lütfen giriş yapınız.');
            });
    }
</script>