@{
    ViewData["Title"] = "Giriş Yap - CinemaShelf";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-success">🍿 CinemaShelf</h2>
                        <p class="text-muted small">Filmlerini düzenlemek ve sosyal akışı görmek için giriş yap.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-pill py-2 px-3 small text-center mb-3" role="alert">
                            ⚠️ @ViewBag.Error
                        </div>
                    }

                    <form action="/Account/Login" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Kullanıcı Adı veya E-posta</label>
                            <input type="text" name="usernameOrEmail" class="form-control rounded-pill" placeholder="Kullanıcı adı veya e-posta girin" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-secondary">Şifre</label>
                            <input type="password" name="password" class="form-control rounded-pill" placeholder="••••••••" required>
                        </div>

                        <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-2 shadow-sm">
                            Giriş Yap 🚀
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">
                            Henüz hesabın yok mu?
                            <a href="/Account/Register" class="text-success fw-semibold text-decoration-none">Hemen Ücretsiz Katıl</a>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
