@{
    ViewData["Title"] = "Kayıt Ol - CinemaShelf";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">🎬 CinemaShelf</h2>
                        <p class="text-muted small">Hemen kaydol, kendi film rafını oluştur ve arkadaşlarını takip et!</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-pill py-2 px-3 small text-center mb-3" role="alert">
                            ⚠️ @ViewBag.Error
                        </div>
                    }

                    <form action="/Account/Register" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Kullanıcı Adı</label>
                            <input type="text" name="username" class="form-control rounded-pill" placeholder="Örn: leyla123" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">E-posta Adresi</label>
                            <input type="email" name="email" class="form-control rounded-pill" placeholder="Örn: leyla@email.com" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-secondary">Şifre</label>
                            <input type="password" name="password" class="form-control rounded-pill" placeholder="••••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                            Kayıt Ol 🎉
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">
                            Zaten bir hesabın var mı?
                            <a href="/Account/Login" class="text-primary fw-semibold text-decoration-none">Giriş Yap</a>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
